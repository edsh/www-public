<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title>D-MRXS Fragesammlung</title>

<style>
body {
    font-family: Arial, Helvetica, sans-serif;
    background: #e6e6e6;
}

/* Hauptbox wie EDSH */
.container {
    width: 850px;
    margin: 40px auto;
    background: white;
    border: 1px solid #999;
    box-shadow: 0 0 10px rgba(0,0,0,0.2);
}

/* Überschrift */
.header {
    background: #2c3e50;
    color: white;
    padding: 15px;
    font-size: 22px;
    font-weight: bold;
}

/* Abschnitt */
.section {
    margin-top: 20px;
}

/* Tabellen-Look */
table {
    width: 100%;
    border-collapse: collapse;
}

th {
    background: #cccccc;
    text-align: left;
    padding: 8px;
    font-size: 16px;
}

td {
    padding: 6px;
    border-bottom: 1px solid #ddd;
}

tr:nth-child(even) {
    background: #f9f9f9;
}

/* Eingaben */
input {
    width: 95%;
    padding: 5px;
    border: 1px solid #aaa;
}

.correct {
    background: #c8f7c5;
}

.wrong {
    background: #f7c5c5;
}

/* Button */
.button-area {
    padding: 15px;
    text-align: center;
}

button {
    padding: 10px 25px;
    font-size: 16px;
    background: #2c3e50;
    color: white;
    border: none;
    cursor: pointer;
}

button:hover {
    background: #1f2d3a;
}

.result {
    text-align: center;
    font-weight: bold;
    padding-bottom: 15px;
}

</style>
</head>

<body>

<div class="container">

<div class="header">Fragesammlung D-MRXS</div>

<table>
<tr><th colspan="2">Betriebsgrenzen</th></tr>

<tr><td>Maximales Abfluggewicht</td><td><input data-answer="472.5"></td></tr>
<tr><td>Leergewicht</td><td><input data-answer="342"></td></tr>
<tr><td>Maximale Zuladung</td><td><input data-answer="130.5"></td></tr>
<tr><td>Zuladung Gepäckfach</td><td><input data-answer="10"></td></tr>

<tr><th colspan="2">Betriebsstoffe</th></tr>

<tr><td>Maximale Treibstoffmenge</td><td><input data-answer="125"></td></tr>
<tr><td>Ausfliegbare Treibstoffmenge</td><td><input data-answer="119"></td></tr>
<tr><td>Zuladung bei vollen Tanks</td><td><input data-answer="29.1"></td></tr>
<tr><td>Treibstoff</td><td><input data-answer="mogas"></td></tr>

<tr><th colspan="2">Geschwindigkeiten</th></tr>

<tr><td>Optimale Steigfluggeschwindigkeit</td><td><input data-answer="115"></td></tr>
<tr><td>Manövergeschwindigkeit</td><td><input data-answer="160"></td></tr>
<tr><td>Max. Geschwindigkeit bei Turbulenz</td><td><input data-answer="130"></td></tr>
<tr><td>Zulässige Höchstgeschwindigkeit</td><td><input data-answer="270"></td></tr>
<tr><td>Max. Klappengeschwindigkeit</td><td><input data-answer="135"></td></tr>
<tr><td>Mindestgeschwindigkeit</td><td><input data-answer="65"></td></tr>
<tr><td>Seitenwindkomponente max.</td><td><input data-answer="44"></td></tr>

<tr><th colspan="2">Motoreinstellungen</th></tr>

<tr><td>Drehzahl Start</td><td><input data-answer="5700"></td></tr>
<tr><td>Drehzahl Landung / Go-Around</td><td><input data-answer="5500"></td></tr>
<tr><td>Drehzahl Reiseflug</td><td><input data-answer="5000"></td></tr>
<tr><td>Dauerleistung max.</td><td><input data-answer="5500"></td></tr>
<tr><td>Maximale Drehzahl</td><td><input data-answer="5800"></td></tr>
<tr><td>Max. Ladedruck</td><td><input data-answer="40.5"></td></tr>

<tr><th colspan="2">Technik</th></tr>

<tr><td>Allgemeine Bauweise</td><td><input data-answer="tiefdecker"></td></tr>
<tr><td>Strukturelle Bauweise</td><td><input data-answer="faserverbund"></td></tr>
<tr><td>Leitwerk</td><td><input data-answer="kreuzleitwerk"></td></tr>
<tr><td>Klappen</td><td><input data-answer="spaltklappen"></td></tr>
<tr><td>Klappenstellungen</td><td><input data-answer="0 15 24 38"></td></tr>
<tr><td>Rudertrimmung</td><td><input data-answer="höhenruder"></td></tr>

<tr><td>Flügelspannweite</td><td><input data-answer="9"></td></tr>
<tr><td>Rumpflänge</td><td><input data-answer="6.4"></td></tr>
<tr><td>Rumpfhöhe</td><td><input data-answer="2"></td></tr>
<tr><td>Lastenvielfaches</td><td><input data-answer="+4"></td></tr>

<tr><th colspan="2">Motor</th></tr>

<tr><td>Motor</td><td><input data-answer="rotax 914"></td></tr>
<tr><td>Motorbauweise</td><td><input data-answer="boxer"></td></tr>
<tr><td>Treibstoff</td><td><input data-answer="mogas"></td></tr>
<tr><td>Anzahl Tanks</td><td><input data-answer="2"></td></tr>
<tr><td>Kraftstoffpumpe</td><td><input data-answer="ja"></td></tr>
<tr><td>Tankwahlschalter</td><td><input data-answer="ja"></td></tr>
<tr><td>TCU Schalter</td><td><input data-answer="an"></td></tr>
<tr><td>TCU Siegel</td><td><input data-answer="intakt"></td></tr>
<tr><td>Propeller</td><td><input data-answer="3"></td></tr>

<tr><th colspan="2">Fahrwerk</th></tr>

<tr><td>Fahrwerk</td><td><input data-answer="festfahrwerk"></td></tr>
<tr><td>Hauptfahrwerk Federung</td><td><input data-answer="gfk"></td></tr>

</table>

<div class="button-area">
<button onclick="check()">Prüfen</button>
</div>

<div class="result" id="result"></div>

</div>

<script>
function norm(t){
    return t.toLowerCase().replace(",",".").trim();
}

function check(){
    let inputs = document.querySelectorAll("input");
    let correct = 0;

    inputs.forEach(i => {
        let u = norm(i.value);
        let a = norm(i.dataset.answer);

        if(u.includes(a)){
            i.classList.add("correct");
            i.classList.remove("wrong");
            correct++;
        } else {
            i.classList.add("wrong");
            i.classList.remove("correct");
        }
    });

    document.getElementById("result").innerText =
        "Ergebnis: " + correct + " / " + inputs.length + " richtig";
}
</script>

</body>
</html>
